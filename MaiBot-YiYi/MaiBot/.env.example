# 复制为 .env 后填写。启动脚本会 load_dotenv；也可在系统环境变量中设置同名项。

# —— 机器人身份（config/bot_config.toml 的 [bot]）——
MAIBOT_QQ_ACCOUNT=2477702109
MAIBOT_NICKNAME=君君

# 多机器人第二实例（config/yiyi_bot_config.toml）
YIYI_QQ_ACCOUNT=
YIYI_BOT_NICKNAME=

# —— 消息服务（maim_message WebSocket /ws；与 MaiBot-Napcat-Adapter [maibot_server] 一致，约定 8091）——
# NapCat 连的是适配器 [napcat_server]（模板默认 8095），不是本端口
HOST=127.0.0.1
PORT=8091

# —— SiliconFlow / 其他 API（config/model_config.toml 已用 ${...}）——
# 真实密钥只写在本地 .env，勿提交 Git；本文件仅作变量名说明
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=
BAILIAN_API_KEY=
GOOGLE_API_KEY=

# —— 其它（非 .env）
# QQ「引用回复」：config/bot_config.toml [chat] → reply_message_quote（never | always | llm）
# 旧规划器门闸（大模型先判该不该说话）：[inner] → v2_enable_legacy_planner_no_reply_gate（默认 true）；planner 模型在 model_config.toml → [model_task_config.planner]
