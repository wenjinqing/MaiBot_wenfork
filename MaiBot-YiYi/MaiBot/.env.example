# ============================================================
# MaiBot 环境变量配置文件示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 将占位符替换为你的真实配置
# 3. .env 文件不会被提交到 Git，请妥善保管
# ============================================================

# ------------------------------------------------------------
# 麦麦主程序配置
# ------------------------------------------------------------
HOST=127.0.0.1
PORT=8000

# ------------------------------------------------------------
# WebUI 独立服务器配置
# ------------------------------------------------------------
WEBUI_ENABLED=true
WEBUI_MODE=production
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8001

# ------------------------------------------------------------
# 机器人账号配置
# ------------------------------------------------------------
# 麦麦的QQ账号
MAIMAI_QQ_ACCOUNT=your-maimai-qq-account-here

# 伊伊的QQ账号
YIYI_QQ_ACCOUNT=your-yiyi-qq-account-here

# ============================================================
# API Keys 配置
# ============================================================

# ------------------------------------------------------------
# DeepSeek API
# ------------------------------------------------------------
# 官网: https://www.deepseek.com/
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ------------------------------------------------------------
# 阿里百炼 (BaiLian) API
# ------------------------------------------------------------
# 官网: https://www.aliyun.com/product/bailian
# 获取 API Key: https://dashscope.aliyuncs.com/
BAILIAN_API_KEY=your-bailian-api-key-here

# ------------------------------------------------------------
# Google AI (Gemini) API
# ------------------------------------------------------------
# 官网: https://ai.google.dev/
# 获取 API Key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ------------------------------------------------------------
# SiliconFlow API
# ------------------------------------------------------------
# 官网: https://siliconflow.cn/
# 获取 API Key: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_TEMPERATURE=0.7
SILICONFLOW_MAX_TOKENS=2000
SILICONFLOW_TOP_P=0.9

# ------------------------------------------------------------
# 工具调用配置
# ------------------------------------------------------------
MAX_TOOL_ROUNDS=5

# ------------------------------------------------------------
# 集成开关
# ------------------------------------------------------------
SILICONFLOW_ENABLE_INTEGRATION=false

# ============================================================
# 安全建议
# ============================================================
# 1. 定期轮换 API Keys
# 2. 不要将 .env 文件提交到版本控制系统
# 3. 如果 API Key 泄露，立即前往服务商平台撤销并重新生成
# 4. 在生产环境中，建议使用系统环境变量或密钥管理服务
# ============================================================
