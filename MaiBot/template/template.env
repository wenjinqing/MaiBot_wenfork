# ============================================================
# MaiBot 环境变量配置文件模板
# ============================================================
# 使用说明：
# 1. 复制此文件到项目根目录并重命名为 .env
# 2. 将下方的占位符替换为你的真实配置
# 3. .env 文件已被 .gitignore 忽略，不会提交到 Git
# ============================================================

# ------------------------------------------------------------
# 麦麦主程序配置
# ------------------------------------------------------------
# 主程序监听地址和端口
HOST=127.0.0.1
PORT=8000

# ------------------------------------------------------------
# WebUI 独立服务器配置
# ------------------------------------------------------------
# 是否启用 WebUI 服务（true/false）
WEBUI_ENABLED=true

# WebUI 运行模式
# - development: 开发模式，提供详细错误信息和热重载
# - production:  生产模式，优化性能和安全性
WEBUI_MODE=production

# WebUI 服务器监听地址
# - 0.0.0.0: 允许外部访问
# - 127.0.0.1: 仅本地访问
WEBUI_HOST=0.0.0.0

# WebUI 服务器端口
WEBUI_PORT=8001

# ============================================================
# API Keys 配置
# ============================================================
# 说明：
# 1. 请将下方的占位符替换为你的真实 API Keys
# 2. 各服务商的 API Key 获取地址见注释
# 3. 如果不使用某个服务，可以保留占位符或删除对应行
# ============================================================

# ------------------------------------------------------------
# DeepSeek API
# ------------------------------------------------------------
# DeepSeek 是一家提供高性能语言模型的服务商
# 官网: https://www.deepseek.com/
# 获取 API Key: https://platform.deepseek.com/
# 定价: 输入 2元/M tokens, 输出 8元/M tokens
DEEPSEEK_API_KEY=your-deepseek-key

# ------------------------------------------------------------
# 阿里百炼 (BaiLian) API
# ------------------------------------------------------------
# 阿里云提供的大模型服务平台
# 官网: https://www.aliyun.com/product/bailian
# 获取 API Key: https://dashscope.aliyuncs.com/
BAILIAN_API_KEY=your-bailian-key

# ------------------------------------------------------------
# Google AI (Gemini) API
# ------------------------------------------------------------
# Google 提供的多模态 AI 模型
# 官网: https://ai.google.dev/
# 获取 API Key: https://makersuite.google.com/app/apikey
# 注意: 需要科学上网访问
GOOGLE_API_KEY=your-google-api-key

# ------------------------------------------------------------
# SiliconFlow API
# ------------------------------------------------------------
# SiliconFlow 是一个开源模型推理平台
# 官网: https://siliconflow.cn/
# 获取 API Key: https://cloud.siliconflow.cn/
# 说明: 提供多种开源模型的 API 服务
SILICONFLOW_API_KEY=your-siliconflow-key

# ============================================================
# 安全建议
# ============================================================
# 1. 定期轮换 API Keys
# 2. 不要将 .env 文件提交到版本控制系统
# 3. 如果 API Key 泄露，立即前往服务商平台撤销并重新生成
# 4. 在生产环境中，建议使用系统环境变量或密钥管理服务
# ============================================================