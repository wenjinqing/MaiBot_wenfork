{
  "manifest_version": 1,
  "name": "能力查询工具 (Capabilities Tool)",
  "version": "1.0.0",
  "description": "查询MaiBot当前已启用的所有功能",
  "author": {
    "name": "SengokuCola",
    "url": "https://github.com/MaiM-with-u"
  },
  "license": "GPL-v3.0-or-later",

  "host_application": {
    "min_version": "0.11.0"
  },
  "homepage_url": "https://github.com/MaiM-with-u/maibot",
  "repository_url": "https://github.com/MaiM-with-u/maibot",
  "keywords": ["capabilities", "tool", "built-in"],
  "categories": ["工具"],

  "default_locale": "zh-CN",
  "locales_path": "_locales",

  "plugin_info": {
    "is_built_in": true,
    "plugin_type": "tool_provider",
    "components": [
      {
        "type": "tool",
        "name": "get_capabilities",
        "description": "查询MaiBot当前已启用的所有功能（插件、动作、命令、工具等）"
      }
    ]
  }
}
